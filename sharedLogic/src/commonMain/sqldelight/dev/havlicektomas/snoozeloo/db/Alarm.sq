CREATE TABLE AlarmEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    title TEXT NOT NULL DEFAULT '',
    hour INTEGER NOT NULL,
    minute INTEGER NOT NULL,
    days TEXT NOT NULL DEFAULT '',
    enabled INTEGER NOT NULL DEFAULT 1,
    ringtoneId TEXT NOT NULL,
    volume INTEGER NOT NULL DEFAULT 50,
    vibrate INTEGER NOT NULL DEFAULT 1
);

selectAll:
SELECT * FROM AlarmEntity ORDER BY hour, minute, id;

selectById:
SELECT * FROM AlarmEntity WHERE id = :id;

insert:
INSERT INTO AlarmEntity(title, hour, minute, days, enabled, ringtoneId, volume, vibrate)
VALUES (:title, :hour, :minute, :days, :enabled, :ringtoneId, :volume, :vibrate);

update:
UPDATE AlarmEntity
SET title = :title, hour = :hour, minute = :minute, days = :days,
    enabled = :enabled, ringtoneId = :ringtoneId, volume = :volume, vibrate = :vibrate
WHERE id = :id;

setEnabled:
UPDATE AlarmEntity SET enabled = :enabled WHERE id = :id;

deleteById:
DELETE FROM AlarmEntity WHERE id = :id;

lastInsertRowId:
SELECT last_insert_rowid();
